# Copia a `api/.env` (no subas secretos al repo).

# --- Datos de workflows (scorecard) ---
# Para usar la base en Supabase:
PROJECTS_DATA_MODE=supabase

# --- Supabase (obligatorio si PROJECTS_DATA_MODE=supabase) ---
# URL exacta: Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co
# Opcional (si la pones, el cliente la usa igual que la de arriba):
# SUPABASE_URL=https://TU_REF.supabase.co

# Clave: Dashboard → API → anon public o service_role (solo servidor).
# Mínimo una de estas (el código las reconoce en este orden):
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# CORS para el front (Vercel), separado por comas si hay varios orígenes.
CORS_ORIGIN=http://localhost:3000

# --- Sincronización automática con n8n / Make ---
# Activa el sync automático al arrancar el API y en intervalos regulares.
EXTERNAL_SYNC_ENABLED=true

# Intervalo entre cada sync (en milisegundos). Por defecto: 300000 (5 minutos).
# Ejemplos: 60000 = 1 min | 300000 = 5 min | 900000 = 15 min
EXTERNAL_SYNC_INTERVAL_MS=300000

# Fuentes a sincronizar (n8n, make o ambas separadas por coma).
# Por defecto sincroniza ambas si están configuradas.
SYNC_SOURCES=n8n,make

# --- n8n ---
# URL base de tu instancia n8n (ej: https://mi-instancia.n8n.cloud)
N8N_API_BASE_URL=
# Clave de API: Settings → n8n API → Create an API key
N8N_API_KEY=
# (Opcional) Filtra solo los workflows de un proyecto específico de n8n
# N8N_PROJECT_ID=

# --- Make (opcional) ---
# URL base según tu región: https://eu1.make.com/api/v2 o https://us1.make.com/api/v2
# MAKE_API_BASE_URL=https://eu1.make.com/api/v2
# MAKE_API_TOKEN=
# MAKE_ORGANIZATION_ID=
