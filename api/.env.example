# Copia este archivo a `api/.env` o a la raíz del repo como `.env` (ambos funcionan; `api/.env` tiene prioridad).
PORT=4000
CORS_ORIGIN=http://localhost:3000

# merged = projects.json + sincronizados | external_only = solo lo traído por sync | json_only = solo projects.json
PROJECTS_DATA_MODE=merged

# Solo n8n (recomendado si no usas Make): SYNC_SOURCES=n8n
# Ambas: SYNC_SOURCES=n8n,make (por defecto si omites esta línea)
SYNC_SOURCES=n8n,make

# Sync automático al arrancar la API
EXTERNAL_SYNC_ENABLED=true
EXTERNAL_SYNC_INTERVAL_MS=300000
# Responsable por defecto al importar workflows (n8n/Make no envían JA/EV): JA | EV
# EXTERNAL_SYNC_DEFAULT_OWNER=EV

# --- n8n (traer workflows a la app) ---
N8N_API_BASE_URL=https://tu-instancia.app.n8n.cloud
N8N_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMGUxMGRmYi03Nzg2LTRlZjMtYjk4NC1hZTFkMjdkNWVkNTEiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwianRpIjoiMWE3MTk4Y2YtNjAxOC00MDdmLWFjNjQtZGU3N2ZmNzMzZTA3IiwiaWF0IjoxNzc2Mjk1NDMxLCJleHAiOjE3Nzg4Mjg0MDB9.AwHy4IXlTCOpTRCUhGgnjprD7xi7c-LK-WTAyreMkXo
